local Pages = {}
local function CreatePage(name)
    local p = Instance.new("Frame", Container)
    p.Size = UDim2.new(1, 0, 1, 0)
    p.BackgroundTransparency = 1
    p.Visible = false
    Pages[name] = p
    return p
end

