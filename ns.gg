local DynamicElements = { Toggles = {}, Sliders = {}, Tabs = {}, MobileToggle = nil }

local function UpdateUIColors(newColor)
    for box, key in pairs(DynamicElements.Toggles) do
        if Config[key] then box.BackgroundColor3 = newColor end
    end
    for _, fill in ipairs(DynamicElements.Sliders) do
        fill.BackgroundColor3 = newColor
    end
    for _, tabData in ipairs(DynamicElements.Tabs) do
        tabData.Indicator.BackgroundColor3 = newColor
    end
    if DynamicElements.MobileToggle then
        DynamicElements.MobileToggle.TextColor3 = newColor
        local stroke = DynamicElements.MobileToggle:FindFirstChildOfClass("UIStroke")
        if stroke then stroke.Color = newColor end
    end
end

