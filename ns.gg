CreateColorPicker("ACCENT THEME BASE COLOR", ThemeSection, "uiColor")

-- SUB-TAB: CONTROLS
local function CreateKeybind(t, p, k)
    local b = Instance.new("TextButton", p)
    b.Size = UDim2.new(1, 0, 0, 24)
    b.BackgroundColor3 = Color3.fromRGB(16, 16, 16)
    b.TextColor3 = Color3.fromRGB(160, 160, 160)
    b.Font = Config.selectedFont
    b.Text = "  " .. t .. ": " .. Config[k].Name
    b.TextXAlignment = Enum.TextXAlignment.Left
    b.BorderSizePixel = 0
    b.MouseButton1Click:Connect(function() 
        b.Text = "  " .. t .. ": ..."
        local conn
        conn = UserInputService.InputBegan:Connect(function(io) 
            if io.UserInputType == Enum.UserInputType.Keyboard then 
                Config[k] = io.KeyCode
                b.Text = "  " .. t .. ": " .. io.KeyCode.Name
                conn:Disconnect() 
            end 
        end) 
    end)
end

CreateKeybind("GUI MENU TOGGLE KEY", SettingsSubs["CONTROLS"], "menuKey")

local UnloadBtn = Instance.new("TextButton", SettingsSubs["CONTROLS"])
UnloadBtn.Size = UDim2.new(1, 0, 0, 28)
UnloadBtn.BackgroundColor3 = Color3.fromRGB(120, 40, 40)
UnloadBtn.Text = "UNLOAD GLOBAL SCRIPT ENVIRONMENT"
UnloadBtn.TextColor3 = Color3.new(1, 1, 1)
UnloadBtn.Font = Config.selectedFont
UnloadBtn.TextSize = 11
UnloadBtn.BorderSizePixel = 0
local EspObjects = {}
UnloadBtn.MouseButton1Click:Connect(function()
    ScriptRunning = false
    ScreenGui:Destroy()
    if KeyGui then KeyGui:Destroy() end
    for _, v in pairs(EspObjects) do
        if v.Box then v.Box:Destroy() end
        if v.Tracer then v.Tracer:Destroy() end
        if v.NameLabel then v.NameLabel:Destroy() end
    end
end)

----------------------------------------------------------------
-- [6] 백엔드 바이패스 제어 & 실시간 싱크 루프 (기능 무수정 보존)
----------------------------------------------------------------
local function IsVisible(part)
    if not Config.wallOn then return true end
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
    params.FilterType = Enum.RaycastFilterType.Exclude
    local result = workspace:Raycast(Camera.CFrame.Position, part.Position - Camera.CFrame.Position, params)
    return not result or result.Instance:IsDescendantOf(part.Parent)
end

local function RemoveEsp(p)
    if EspObjects[p] then
        if EspObjects[p].Box then EspObjects[p].Box:Destroy() end
        if EspObjects[p].Tracer then EspObjects[p].Tracer:Destroy() end
        if EspObjects[p].NameLabel then EspObjects[p].NameLabel:Destroy() end
        EspObjects[p] = nil
    end
end

local function CreateEsp(p)
    local obj = { Box = Instance.new("Frame", ScreenGui), Tracer = Instance.new("Frame", ScreenGui), NameLabel = Instance.new("TextLabel", ScreenGui) }
    obj.Box.BackgroundTransparency = 1
    obj.Box.BorderSizePixel = 1
    obj.Box.Visible = false
    Instance.new("UIStroke", obj.Box).Thickness = 1
    obj.Tracer.BorderSizePixel = 0
    obj.Tracer.Visible = false
    obj.Tracer.AnchorPoint = Vector2.new(0.5, 0.5)
    obj.NameLabel.BackgroundTransparency = 1
    obj.NameLabel.Visible = false
    obj.NameLabel.TextSize = 11
    obj.NameLabel.Font = Config.selectedFont
    EspObjects[p] = obj
end

Players.PlayerRemoving:Connect(RemoveEsp)

local FOVCircle = Instance.new("Frame", ScreenGui)
FOVCircle.BackgroundTransparency = 0.8
FOVCircle.BorderSizePixel = 0
FOVCircle.Visible = false
Instance.new("UICorner", FOVCircle).CornerRadius = UDim.new(1, 0)

VerifyBtn.MouseButton1Click:Connect(function()
    if KeyInput.Text == CorrectKey then 
        KeyVerified = true
        KeyGui:Destroy()
        ScreenGui.Enabled = true
    else 
        VerifyBtn.Text = "INVALID KEY SYSTEM MATCH!"
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(150, 20, 20)
        task.wait(1)
        VerifyBtn.Text = "VERIFY KEY"
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(170, 85, 255) 
    end
end)

-- GC 가비지 수집 무력화 동기화 테이블 루프
task.spawn(function()
    while task.wait(0.2) do
        if not KeyVerified or not ScriptRunning then continue end
        pcall(function()
            for _, v in pairs(getgc(true)) do
                if type(v) == "table" then
                    if Config.instantReload and (rawget(v, "reloadtime") or rawget(v, "m_reloadtime") or rawget(v, "ReloadTime")) then
                        v.reloadtime = 0; v.m_reloadtime = 0; v.ReloadTime = 0
                        if v.reloading then v.reloading = false end
                    end
                    if Config.rapidFire and (rawget(v, "firerate") or rawget(v, "FireRate")) then
                        v.firerate = 0.001; v.FireRate = 0.001
                    end
                    if Config.antiSpread and (rawget(v, "spread") or rawget(v, "Spread")) then
                        v.spread = 0; v.Spread = 0
                    end
                end
            end
        end)
    end
end)

-- 무한 아모 및 안티 반동 강제 고정 루프
task.spawn(function()
    while task.wait(0.01) do
        if not KeyVerified or not ScriptRunning then continue end
        
        if Config.infAmmo then
            pcall(function()
                local v168 = game.ReplicatedStorage:FindFirstChild("wkspc")
                if v168 and v168:FindFirstChild("CurrentCurse") then
                    v168.CurrentCurse.Value = "Infinite Ammo"
                end
            end)
            
            pcall(function()
                local v169 = game.ReplicatedStorage:FindFirstChild("Weapons")
                if v169 then
                    for _, v173 in pairs(v169:GetChildren()) do
                        if v173:FindFirstChild("Ammo") and v173.Ammo:IsA("IntValue") then
                            v173.Ammo.Value = 360
                        end
                    end
                end
            end)
        end

        pcall(function()
            local weaponsFolder = game.ReplicatedStorage:FindFirstChild("Weapons")
            if weaponsFolder then
                for _, v143 in pairs(weaponsFolder:GetDescendants()) do
                    if v143:IsA("NumberValue") and (v143.Name == "Recoil" or v143.Name == "RecoilControl") then
                        if Config.antiRecoil then
                            vu137.Recoil[v143] = vu137.Recoil[v143] or v143.Value
                            v143.Value = 0
                        else
                            v143.Value = vu137.Recoil[v143] or v143.Value
                        end
                    end
                end
            end
        end)
    end
end)

-- 1인칭 암즈 스킨 체인저 및 오버라이드 우회 루프
task.spawn(function()
    while task.wait(0.01) do
        if not KeyVerified or not ScriptRunning then continue end
        
        local wpFolder = ReplicatedStorage:FindFirstChild("Weapons")
        if wpFolder then
            for _, gun in pairs(wpFolder:GetChildren()) do
                if Config.rapidFire and gun:FindFirstChild("FireRate") then gun.FireRate.Value = 0.01 end
                if Config.instantReload and gun:FindFirstChild("ReloadTime") then gun.ReloadTime.Value = 0 end
                if Config.antiSpread and gun:FindFirstChild("Spread") then gun.Spread.Value = 0 end
                if Config.alwaysAuto then
                    for _, val in pairs(gun:GetChildren()) do
                        if val:IsA("BoolValue") and string.find(string.lower(val.Name), "auto") then val.Value = true end
                    end
                end
            end
        end

        local arms = Camera:FindFirstChild("Arms")
        if arms then
            for _, part in pairs(arms:GetDescendants()) do
                if part:IsA("BasePart") then
                    if Config.transparentGun then part.Transparency = 0.8 else part.Transparency = 0 end
                    if Config.purplishGun then
                        part.Color = Config.gunColor
                        local sa = part:FindFirstChildOfClass("SurfaceAppearance")
                        if sa then sa:Destroy() end
                    end
                end
            end
        end
    end
end)

local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
setreadonly(mt, false)
mt.__namecall = newcclosure(function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    if method == "FireServer" and self.Name == "ShootEvent" and Config.noSpray then
        args[1] = Camera.CFrame.Position + (Camera.CFrame.LookVector * 500)
        return oldNamecall(self, unpack(args))
    end
    return oldNamecall(self, ...)
end)
setreadonly(mt, true)

-- 메인 프레임 렌더 단계 코어 핸들러
RunService.RenderStepped:Connect(function()
    if not KeyVerified or not ScriptRunning then return end
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    TopBar.BackgroundColor3 = Config.uiColor
    MainStroke.Color = Config.uiColor

    pcall(function()
        Lighting.Brightness = Config.brightnessVal
        Lighting.ClockTime = Config.clockTimeVal
        Lighting.FogEnd = Config.fogEnd
        local targetAmbient = Color3.fromRGB(Config.worldR, Config.worldG, Config.worldB)
        Lighting.Ambient = targetAmbient
        Lighting.OutdoorAmbient = targetAmbient
    end)

    if Config.triggerOn then
        local currentTime = tick()
        if currentTime - lastTriggerShotTime >= Config.triggerDelay then
            local targetObject = Mouse.Target
            if targetObject and targetObject.Parent then
                local hitCharacter = targetObject.Parent
                if hitCharacter:FindFirstChild("Head") and hitCharacter:FindFirstChild("Humanoid") then
                    local targetPlayer = Players:GetPlayerFromCharacter(hitCharacter)
                    if targetPlayer and targetPlayer ~= LocalPlayer and (not Config.teamOn or targetPlayer.Team ~= LocalPlayer.Team) then
                        mouse1press()
                        task.wait(0.01)
                        mouse1release()
                        lastTriggerShotTime = currentTime
                    end
                end
            end
        end
    end

    local currentBestTarget, minMag = nil, Config.fovRadius
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            if not EspObjects[p] then CreateEsp(p) end
            local obj = EspObjects[p]
            local tChar = p.Character
            local tHRP = tChar and tChar:FindFirstChild("HumanoidRootPart")
            local tHum = tChar and tChar:FindFirstChild("Humanoid")
            
            if tChar and tHum and tHum.Health > 0 then
                for _, partName in pairs({"Head", "HumanoidRootPart", "UpperTorso"}) do
                    local pPart = tChar:FindFirstChild(partName)
                    if pPart and pPart:IsA("BasePart") then
                        if Config.silentOn and not (Config.teamOn and p.Team == LocalPlayer.Team) then
                            pPart.Size = Vector3.new(20, 20, 20)
                            pPart.Transparency = 1
                            pPart.CanCollide = false
                        else
                            if partName == "Head" then pPart.Size = Vector3.new(1.2, 1.2, 1.2) else pPart.Size = Vector3.new(2, 2, 1) end
                            pPart.Transparency = 0
                            pPart.CanCollide = true
                        end
                        
                        if Config.aimOn and partName == Config.aimPart and not (Config.teamOn and p.Team == LocalPlayer.Team) then
                            pPart.Color = Config.uiColor
                        else
                            pPart.Color = Color3.fromRGB(255, 255, 255)
                        end
                    end
                end
            end
            
            if tChar and tHRP and tHum and tHum.Health > 0 and not (Config.teamOn and p.Team == LocalPlayer.Team) then
                local pos, onScreen = Camera:WorldToViewportPoint(tHRP.Position)
                if onScreen and Config.espOn then
                    local top = Camera:WorldToViewportPoint(tHRP.Position + Vector3.new(0, 3, 0))
                    local bottom = Camera:WorldToViewportPoint(tHRP.Position - Vector3.new(0, 3.5, 0))
                    local boxHeight = math.abs(top.Y - bottom.Y)
                    local boxWidth = boxHeight / 1.6
                    if Config.espBox then
                        obj.Box.Visible = true
                        obj.Box.Size = UDim2.new(0, boxWidth, 0, boxHeight)
                        obj.Box.Position = UDim2.new(0, pos.X - boxWidth / 2, 0, pos.Y - boxHeight / 2)
                        if obj.Box:FindFirstChildOfClass("UIStroke") then
                            obj.Box:FindFirstChildOfClass("UIStroke").Color = Config.espColor
                        end
                    else obj.Box.Visible = false end
                    if Config.espTracer then
                        obj.Tracer.Visible = true
                        obj.Tracer.BackgroundColor3 = Config.espColor
                        local start = Vector2.new(center.X, center.Y * 2)
                        local endP = Vector2.new(pos.X, pos.Y)
                        local mag = (endP - start).Magnitude
                        obj.Tracer.Size = UDim2.new(0, mag, 0, 1)
                        obj.Tracer.Position = UDim2.new(0, (start.X + endP.X) / 2, 0, (start.Y + endP.Y) / 2)
                        obj.Tracer.Rotation = math.deg(math.atan2(endP.Y - start.Y, endP.X - start.X))
                    else obj.Tracer.Visible = false end
                    if Config.espName then
                        obj.NameLabel.Visible = true
                        obj.NameLabel.TextColor3 = Config.espColor
                        obj.NameLabel.Font = Config.selectedFont
                        obj.NameLabel.Text = p.Name .. (Config.espDist and " [" .. math.floor((tHRP.Position - hrp.Position).Magnitude) .. "m]" or "")
                        obj.NameLabel.Position = UDim2.new(0, pos.X, 0, pos.Y - (boxHeight / 2) - 15)
                    else obj.NameLabel.Visible = false end
                    local mag = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if mag < minMag then 
                        local tPart = tChar:FindFirstChild(Config.aimPart) 
                        if tPart and IsVisible(tPart) then currentBestTarget, minMag = tChar, mag end 
                    end
                else 
                    obj.Box.Visible = false
                    obj.Tracer.Visible = false
                    obj.NameLabel.Visible = false 
                end
            else 
                if obj then 
                    obj.Box.Visible = false
                    obj.Tracer.Visible = false
                    obj.NameLabel.Visible = false 
                end 
            end
        end
    end
    
    FOVCircle.Visible = Config.showFov
    if Config.showFov then 
        FOVCircle.Size = UDim2.new(0, Config.fovRadius * 2, 0, Config.fovRadius * 2)
        FOVCircle.Position = UDim2.new(0, center.X - Config.fovRadius, 0, center.Y - Config.fovRadius)
        FOVCircle.BackgroundColor3 = Config.fovColor 
    end
    
    if Config.aimOn and currentBestTarget then
        if currentBestTarget ~= lastTarget then 
            lastTarget = currentBestTarget
            lockStartTime = tick() 
        end
        if (tick() - lockStartTime) >= Config.aimDelay then
            local aimPart = currentBestTarget:FindFirstChild(Config.aimPart)
            if aimPart then Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, aimPart.Position), 1 / Config.aimSmooth) end
        end
    else lastTarget = nil end

    if hum then hum.WalkSpeed = Config.wsOn and Config.walkSpeedVal or 16 end

    if Config.flyOn and hrp and hum then
        hrp.Velocity = Vector3.new(0, 0, 0)
        local moveDir = Vector3.new(0, 0, 0)
        local camCF = Camera.CFrame
        if IsMobile then
            local joyMove = hum.MoveDirection
            if joyMove.Magnitude > 0 then moveDir = (camCF.Rotation * CFrame.new(joyMove.X, 0, joyMove.Z)).Position end
        else
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + camCF.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - camCF.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - camCF.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + camCF.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0, 1, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir = moveDir - Vector3.new(0, 1, 0) end
        end
        if moveDir.Magnitude > 0 then hrp.CFrame = hrp.CFrame + (moveDir.Unit * (Config.flySpeedVal / 15)) end
    end
end)

RunService.Stepped:Connect(function() 
    if ScriptRunning and KeyVerified and LocalPlayer.Character and Config.noclipOn then 
        for _, v in pairs(LocalPlayer.Character:GetDescendants()) do 
            if v:IsA("BasePart") then v.CanCollide = false end 
        end 
    end 
end)

UserInputService.InputBegan:Connect(function(io, gpe)
    if not ScriptRunning or not KeyVerified or gpe then return end
    if io.KeyCode == Config.menuKey then Main.Visible = not Main.Visible
    elseif io.KeyCode == Config.aimKey then Config.aimOn = not Config.aimOn
    elseif io.KeyCode == Config.espKey then Config.espOn = not Config.espOn end
end)
