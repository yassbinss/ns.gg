local FontSection = CreateSection("INTERFACE FONTS", SettingsSubs["UI DESIGN"])
local fonts = {Enum.Font.Code, Enum.Font.Gotham, Enum.Font.Roboto, Enum.Font.Ubuntu, Enum.Font.TitilliumWeb, Enum.Font.Sarpanch}
local FontGrid = Instance.new("Frame", FontSection)
FontGrid.Size = UDim2.new(1, 0, 0, 60)
FontGrid.BackgroundTransparency = 1
local FUIGrid = Instance.new("UIGridLayout", FontGrid)
FUIGrid.CellSize = UDim2.new(0.31, 0, 0, 22)
FUIGrid.CellPadding = UDim2.new(0.02, 0, 0, 4)
for _, f in ipairs(fonts) do
    local btn = Instance.new("TextButton", FontGrid)
    btn.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Text = f.Name
    btn.Font = f
    btn.TextSize = 11
    btn.BorderSizePixel = 0
    btn.MouseButton1Click:Connect(function() 
        Config.selectedFont = f
        for _, v in pairs(ScreenGui:GetDescendants()) do 
            if v:IsA("TextLabel") or v:IsA("TextButton") then v.Font = f end 
        end 
    end)
end

