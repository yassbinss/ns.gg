----------------------------------------------------------------
-- [Sub-Tab 시스템 상시 가동 빌더]
----------------------------------------------------------------
local function CreateSubTabStructure(parentPage, subTabNames)
    local SubTabHeader = Instance.new("Frame", parentPage)
    SubTabHeader.Size = UDim2.new(1, 0, 0, 28)
    SubTabHeader.BackgroundColor3 = Color3.fromRGB(14, 14, 14)
    SubTabHeader.BorderSizePixel = 0
    local SubHeaderStroke = Instance.new("UIStroke", SubTabHeader)
    SubHeaderStroke.Color = Color3.fromRGB(25, 25, 25)
    
    local SubTabLayout = Instance.new("UIListLayout", SubTabHeader)
    SubTabLayout.FillDirection = Enum.FillDirection.Horizontal
    SubTabLayout.Padding = UDim.new(0, 1)
    
    local SubContentFrame = Instance.new("Frame", parentPage)
    SubContentFrame.Size = UDim2.new(1, -16, 1, -40)
    SubContentFrame.Position = UDim2.new(0, 8, 0, 36)
    SubContentFrame.BackgroundTransparency = 1
    
    local subContainers = {}
    local subButtons = {}
    
    for i, name in ipairs(subTabNames) do
        local sc = Instance.new("ScrollingFrame", SubContentFrame)
        sc.Size = UDim2.new(1, 0, 1, 0)
        sc.BackgroundTransparency = 1
        sc.Visible = (i == 1)
        sc.ScrollBarThickness = 2
        sc.CanvasSize = UDim2.new(0, 0, 0, 0)
        sc.AutomaticCanvasSize = Enum.AutomaticSize.Y
        sc.Selectable = true
        sc.Active = true
        
        local scList = Instance.new("UIListLayout", sc)
        scList.Padding = UDim.new(0, 6)
        subContainers[name] = sc
        
        local btn = Instance.new("TextButton", SubTabHeader)
        btn.Size = UDim2.new(0, math.floor(350 / #subTabNames), 1, 0)
        btn.BackgroundColor3 = (i == 1) and Color3.fromRGB(22, 22, 22) or Color3.fromRGB(16, 16, 16)
        btn.TextColor3 = (i == 1) and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(140, 140, 140)
        btn.Font = Enum.Font.Code
        btn.Text = name
        btn.TextSize = 11
        btn.BorderSizePixel = 0
        subButtons[name] = btn
        
        btn.MouseButton1Click:Connect(function()
            for _, frame in pairs(subContainers) do frame.Visible = false end
            for _, sBtn in pairs(subButtons) do
                sBtn.BackgroundColor3 = Color3.fromRGB(16, 16, 16)
                sBtn.TextColor3 = Color3.fromRGB(140, 140, 140)
            end
            sc.Visible = true
            btn.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        end)
    end
    return subContainers
end

local CombatSubs = CreateSubTabStructure(CombatPage, {"AIMBOT", "SILENT AIM", "TRIGGERBOT"})
local VisualsSubs = CreateSubTabStructure(VisualsPage, {"PLAYER ESP", "WORLD SETTINGS", "SKIN CHANGER"})
local MiscSubs = CreateSubTabStructure(MiscPage, {"MOVEMENT", "GUN MODS"})
local SettingsSubs = CreateSubTabStructure(SettingsPage, {"UI DESIGN", "CONTROLS"})

local function CreateTab(t, p)
    local b = Instance.new("TextButton", TabContainer)
    b.Size = UDim2.new(1, 0, 0, 32)
    b.BackgroundColor3 = Color3.fromRGB(16, 16, 16)
    b.TextColor3 = Color3.fromRGB(130, 130, 130)
    b.Font = Enum.Font.Code
    b.Text = "  " .. t
    b.BorderSizePixel = 0
    b.TextSize = 13
    b.TextXAlignment = Enum.TextXAlignment.Left
    local Indicator = Instance.new("Frame", b)
    Indicator.Size = UDim2.new(0, 3, 1, 0)
    Indicator.Position = UDim2.new(0, 0, 0, 0)
    Indicator.BackgroundColor3 = Config.uiColor
    Indicator.BorderSizePixel = 0
    Indicator.Visible = false
    
    table.insert(DynamicElements.Tabs, { Button = b, Indicator = Indicator })
    
    b.MouseButton1Click:Connect(function()
        for _, v in pairs(Pages) do v.Visible = false end
        for _, v in pairs(TabContainer:GetChildren()) do 
            if v:IsA("TextButton") then 
                v.TextColor3 = Color3.fromRGB(130, 130, 130) 
                if v:FindFirstChild("Frame") then v:FindFirstChild("Frame").Visible = false end 
            end 
        end
        p.Visible = true
        b.TextColor3 = Color3.fromRGB(255, 255, 255)
        Indicator.Visible = true
    end)
    if t == "COMBAT" then 
        b.TextColor3 = Color3.fromRGB(255, 255, 255)
        Indicator.Visible = true 
    end
end

CreateTab("COMBAT", CombatPage)
CreateTab("VISUALS", VisualsPage)
CreateTab("MISC", MiscPage)
CreateTab("SETTINGS", SettingsPage)

----------------------------------------------------------------
-- [4] 위젯 팩토리 유틸리티 함수
----------------------------------------------------------------
local function CreateSection(t, p)
    local section = Instance.new("Frame", p)
    section.Size = UDim2.new(1, 0, 0, 26)
    section.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    section.BorderSizePixel = 0
    section.ClipsDescendants = true
    
    local btn = Instance.new("TextButton", section)
    btn.Size = UDim2.new(1, 0, 0, 26)
    btn.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
    btn.Text = " > " .. t
    btn.TextColor3 = Color3.fromRGB(200, 200, 200)
    btn.Font = Enum.Font.Code
    btn.TextSize = 11
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.BorderSizePixel = 0
    
    local content = Instance.new("Frame", section)
    content.Size = UDim2.new(1, 0, 0, 0)
    content.Position = UDim2.new(0, 0, 0, 26)
    content.BackgroundTransparency = 1
    content.Visible = false
    
    local list = Instance.new("UIListLayout", content)
    list.Padding = UDim.new(0, 5)
    list.HorizontalAlignment = Enum.HorizontalAlignment.Center
    
    btn.MouseButton1Click:Connect(function()
        content.Visible = not content.Visible
        if content.Visible then
            local h = list.AbsoluteContentSize.Y + 8
            content.Size = UDim2.new(1, 0, 0, h)
            section.Size = UDim2.new(1, 0, 0, h + 30)
        else
            section.Size = UDim2.new(1, 0, 0, 26)
        end
    end)
    return content
end

local function CreateToggle(t, p, k)
    local b = Instance.new("TextButton", p)
    b.Size = UDim2.new(1, 0, 0, 24)
    b.BackgroundColor3 = Color3.fromRGB(16, 16, 16)
    b.TextColor3 = Color3.fromRGB(160, 160, 160)
    b.Font = Config.selectedFont
    b.BorderSizePixel = 0
    b.TextSize = 12
    b.TextXAlignment = Enum.TextXAlignment.Left
    b.Active = true
    
    local box = Instance.new("Frame", b)
    box.Size = UDim2.new(0, 12, 0, 12)
    box.Position = UDim2.new(1, -16, 0.5, -6)
    box.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    box.BorderSizePixel = 0
    local boxStroke = Instance.new("UIStroke", box)
    boxStroke.Color = Color3.fromRGB(45, 45, 45)
    boxStroke.Thickness = 1
    
    DynamicElements.Toggles[box] = k
    
    local function up() 
        b.Text = "  " .. t
        if Config[k] then 
            box.BackgroundColor3 = Config.uiColor
            b.TextColor3 = Color3.fromRGB(255, 255, 255)
        else 
            box.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            b.TextColor3 = Color3.fromRGB(160, 160, 160) 
        end
    end
    up()
    b.MouseButton1Click:Connect(function() Config[k] = not Config[k]; up() end)
end

local function CreateSlider(t, p, min, max, k, isFloat)
    local f = Instance.new("Frame", p)
    f.Size = UDim2.new(1, 0, 0, 38)
    f.BackgroundTransparency = 1
    f.Active = true
    
    local l = Instance.new("TextLabel", f)
    l.Size = UDim2.new(1, 0, 0, 18)
    l.Text = "  " .. t .. ": " .. Config[k]
    l.TextColor3 = Color3.fromRGB(180, 180, 180)
    l.BackgroundTransparency = 1
    l.Font = Config.selectedFont
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.TextSize = 11
    
    local bg = Instance.new("Frame", f)
    bg.Size = UDim2.new(1, -4, 0, 4)
    bg.Position = UDim2.new(0, 2, 0, 24)
    bg.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    bg.BorderSizePixel = 0
    
    local fill = Instance.new("Frame", bg)
    fill.Size = UDim2.new((Config[k]-min)/(max-min), 0, 1, 0)
    fill.BackgroundColor3 = Config.uiColor
    fill.BorderSizePixel = 0
    
    table.insert(DynamicElements.Sliders, fill)
    
    local dragging = false
    local function Update(input)
        local pos = math.clamp((input.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
        local val = min + (max - min) * pos
        if isFloat then val = math.floor(val * 100) / 100 else val = math.floor(val) end 
        Config[k] = val
        fill.Size = UDim2.new(pos, 0, 1, 0)
        l.Text = "  " .. t .. ": " .. val
    end
    
    f.InputBegan:Connect(function(input) 
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then 
            dragging = true; Update(input) 
        end 
    end)
    UserInputService.InputChanged:Connect(function(input) 
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then 
            Update(input) 
        end 
    end)
    UserInputService.InputEnded:Connect(function(input) 
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then 
            dragging = false 
        end 
    end)
end

local function CreateColorPicker(t, p, k)
    local f = Instance.new("Frame", p)
    f.Size = UDim2.new(1, 0, 0, 40)
    f.BackgroundTransparency = 1
    f.Active = true
    
    local l = Instance.new("TextLabel", f)
    l.Size = UDim2.new(1, 0, 0, 16)
    l.Text = "  " .. t
    l.TextColor3 = Color3.fromRGB(160, 160, 160)
    l.Font = Config.selectedFont
    l.TextSize = 11
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.BackgroundTransparency = 1 
    
    local container = Instance.new("Frame", f)
    container.Size = UDim2.new(1, 0, 0, 20)
    container.Position = UDim2.new(0, 0, 0, 18)
    container.BackgroundTransparency = 1
    
    local colors = {Color3.new(1,0,0), Color3.new(0,1,0), Color3.new(0,0,1), Color3.new(1,1,0), Color3.new(1,0,1), Color3.new(1,1,1), Color3.fromRGB(170, 85, 255), Color3.fromRGB(255, 127, 0)}
    local grid = Instance.new("UIGridLayout", container)
    grid.CellSize = UDim2.new(0, 18, 0, 18)
    grid.CellPadding = UDim2.new(0, 4, 0, 4)
    
    for _, c in ipairs(colors) do
        local b = Instance.new("TextButton", container)
        b.BackgroundColor3 = c
        b.Text = ""
        b.BorderSizePixel = 0
        b.MouseButton1Click:Connect(function() 
            Config[k] = c 
            if k == "uiColor" then 
                TopBar.BackgroundColor3 = c 
                MainStroke.Color = c 
                UpdateUIColors(c)
            end 
        end)
    end
end

